// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  organizer
  admin
}

enum EventCategory {
  concert
  conference
  festival
  sport
  theatre
  exposition
  autre
}

enum TicketStatus {
  pending
  paid
  used
  cancelled
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events  Event[]
  tickets Ticket[]

  @@map("users")
}

model Event {
  id          String        @id @default(uuid())
  title       String
  description String        @db.Text
  date        DateTime
  location    String
  price       Float
  capacity    Int
  category    EventCategory @default(autre)
  imageUrl    String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  tickets     Ticket[]

  @@index([date])
  @@index([location])
  @@index([organizerId])
  @@index([category])
  @@index([deletedAt])
  @@map("events")
}

model Ticket {
  id              String       @id @default(uuid())
  status          TicketStatus @default(pending)
  qrCode          String?
  stripeSessionId String?      @unique
  purchaseDate    DateTime     @default(now())
  validatedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@map("tickets")
}
