# Port du serveur
PORT=3000

# URL de connexion PostgreSQL
# Pour Docker: postgresql://postgres:postgres@db:5432/rifle_db?schema=public
# Pour local: postgresql://USER:PASSWORD@localhost:5432/rifle_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@db:5432/rifle_db?schema=public"

# Variables d'environnement pour l'application
NODE_ENV=development

# Configuration SMTP pour l'envoi de mails
# Gmail : activer "Mots de passe d'application" dans les paramètres de sécurité du compte
# Mailtrap (tests) : https://mailtrap.io
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Rifle Events <your-email@gmail.com>"
